{
  "name": "exocortex-obsidian-plugin",
  "version": "5.0.0",
  "description": "Exocortex: A simplified Obsidian plugin for enhanced note management",
  "main": "main.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "check:types": "tsc --noEmit --skipLibCheck",
    "test": "jest",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "exocortex",
    "knowledge-base"
  ],
  "author": "A. Kitelev",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.19.0",
    "@typescript-eslint/eslint-plugin": "^5.29.0",
    "@typescript-eslint/parser": "^5.29.0",
    "builtin-modules": "3.3.0",
    "esbuild": "0.17.3",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "jsdom": "^26.1.0",
    "obsidian": "latest",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.1",
    "tslib": "^2.8.1",
    "typescript": "4.7.4"
  },
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "js-yaml": "^4.1.0",
    "uuid": "^11.1.0"
  }
}
