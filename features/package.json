{
  "name": "exocortex-bdd-tests",
  "version": "1.0.0",
  "description": "BDD Test Suite for Exocortex Plugin Refactoring",
  "scripts": {
    "test:bdd": "tsx test-framework/bdd-test-runner.ts",
    "test:bdd:core": "tsx test-framework/bdd-test-runner.ts --feature=core-functionality-preservation",
    "test:bdd:removal": "tsx test-framework/bdd-test-runner.ts --feature=functionality-removal",
    "test:bdd:architecture": "tsx test-framework/bdd-test-runner.ts --feature=clean-architecture-validation",
    "test:bdd:verbose": "tsx test-framework/bdd-test-runner.ts --verbose",
    "test:bdd:fail-fast": "tsx test-framework/bdd-test-runner.ts --fail-fast",
    "lint": "eslint **/*.ts",
    "format": "prettier --write **/*.{ts,js,json,md}"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "glob": "^10.0.0"
  },
  "dependencies": {
    "@cucumber/cucumber": "^10.0.0",
    "jest": "^29.0.0",
    "obsidian": "^1.5.0"
  },
  "keywords": [
    "bdd",
    "gherkin",
    "testing",
    "obsidian",
    "plugin",
    "refactoring"
  ]
}